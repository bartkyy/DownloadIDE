{
  "name": "ide",
  "version": "1.1.0-beta",
  "description": "...",
  "author": "bartkyy",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win"
  },
  "build": {
    "appId": "https://github.com/bartkyy",
    "win": {
      "target": "nsis",
      "icon": "icon.ico"
    },
    "extraResources": [
        {
            "from": "kompiler.exe",
            "to": "kompiler.exe"
        }
    ],
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "installerIcon": "icon-install.ico",
      "uninstallerIcon": "icon-uninstall.ico"
    },
    "files": [
      "**/*",
      "kompiler.exe"
    ]
  },
  "devDependencies": {
    "electron": "^25.0.0",
    "electron-builder": "^24.0.0"
  }
}
